---
// Emits FAQPage JSON-LD for a page's FAQ items. Usage rules:
// - At most one FaqJsonLd per page, and only from .astro pages, so each URL
//   has exactly one FAQPage block.
// - The same items array must also be rendered visibly on the page through
//   FaqList or FaqSection. Google requires schema content to be visible.
// - FAQPage coexists with Product, Article, and other schema types as sibling
//   script tags. Never nest it inside another schema object.
// - Since August 2023 Google shows FAQ rich results only for authoritative
//   government and health sites. The value here is long-tail content and
//   AI-answer extraction; the schema is nearly free since it derives from the
//   same data module as the visible rendering.
import { faqPageSchema, type FaqItem } from '@/data/faqs/types';
import { jsonLdString } from '@/lib/jsonLd';

interface Props {
	items: FaqItem[];
}

const { items } = Astro.props;

const json = jsonLdString(faqPageSchema(items));
---

<script type="application/ld+json" set:html={json} />
