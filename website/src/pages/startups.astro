---
import { getImage } from 'astro:assets';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import StartupsPage from '@/components/marketing/startups/StartupsPage';
const imgFounders = { src: "https://assets.rivet.dev/website/images/yc-founders.jpg", width: 5925, height: 3942, format: "jpg" };
const imgSpeedrun = { src: "https://assets.rivet.dev/website/images/a16z-speedrun.jpg", width: 2048, height: 1365, format: "jpg" };
const optimizedFounders = await getImage({
	src: imgFounders,
	width: 1280,
	format: 'webp',
	quality: 90
});

const optimizedSpeedrun = await getImage({
	src: imgSpeedrun,
	width: 1280,
	format: 'webp',
	quality: 90
});
---

<MarketingLayout
	title="Startups - Rivet"
	description="50% off Rivet Cloud for YC and a16z Speedrun companies. Build stateful serverless applications at startup speed."
	canonicalUrl="https://rivet.dev/startups/"
>
	<StartupsPage
		client:load
		foundersImage={optimizedFounders.src}
		speedrunImage={optimizedSpeedrun.src}
	/>
</MarketingLayout>
