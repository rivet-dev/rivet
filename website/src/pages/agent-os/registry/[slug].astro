---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Icon } from '@rivet-gg/icons';
import { registry } from '@/data/registry';

export function getStaticPaths() {
	return registry.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;

const TYPE_LABELS: Record<string, string> = {
	"file-system": "File System",
	tool: "ToolKit",
	agent: "Agent",
	"sandbox-extension": "Sandbox Mounting",
};

const TYPE_COLORS: Record<string, string> = {
	"file-system": "bg-blue-50 text-blue-600 border-blue-200",
	tool: "bg-emerald-50 text-emerald-600 border-emerald-200",
	agent: "bg-orange-50 text-orange-600 border-orange-200",
	"sandbox-extension": "bg-purple-50 text-purple-600 border-purple-200",
};

const isComingSoon = entry.status === "coming-soon";
const installCmd = !isComingSoon ? `npm install ${entry.package}` : null;
---

<MarketingLayout
	title={entry.title}
	description={entry.description}
	canonicalUrl={`https://rivet.dev/agent-os/registry/${entry.slug}/`}
>
	<main class="min-h-screen w-full overflow-x-hidden bg-white selection:bg-zinc-200 selection:text-zinc-900">
		<div class="relative isolate overflow-hidden pt-40">
			<div class="mx-auto max-w-3xl px-6 lg:px-8">
				<a
					href="/agent-os/registry"
					class="inline-flex items-center text-sm text-zinc-400 hover:text-zinc-900 mb-8 transition-colors no-underline"
				>
					&larr; Back to Registry
				</a>

				<div class="flex items-center gap-4 mb-4">
					{entry.image && (
						<img
							src={entry.image}
							alt={entry.title}
							width={40}
							height={40}
							class="object-contain"
						/>
					)}
					{entry.icon && (
						<Icon icon={entry.icon} className="text-zinc-900 w-10 h-10" />
					)}
					<h1 class="text-5xl font-700 text-zinc-900 leading-[1.1] tracking-normal">
						{entry.title}
					</h1>
					{isComingSoon && (
						<span class="text-xs px-2.5 py-1 rounded-full border border-zinc-200 text-zinc-400">
							Coming Soon
						</span>
					)}
				</div>

				<div class="flex gap-2 mt-4">
					{entry.types.map((type: string) => (
						<span
							class={`text-xs px-2 py-0.5 rounded-full border ${TYPE_COLORS[type]}`}
						>
							{TYPE_LABELS[type]}
						</span>
					))}
				</div>

				<p class="mt-6 text-lg text-zinc-500 leading-relaxed">
					{entry.description}
				</p>
			</div>
		</div>

		<div class="mx-auto max-w-3xl px-6 lg:px-8 pt-10 pb-24">
			{isComingSoon ? (
				<div class="rounded-xl border border-zinc-200 bg-zinc-50 p-8 text-center">
					<p class="text-zinc-400 text-lg">This integration is coming soon.</p>
				</div>
			) : (
				<>
					<section>
						<h2 class="text-xl font-600 text-zinc-900 mb-3">Install</h2>
						<div class="flex items-center gap-2 bg-zinc-50 rounded-lg border border-zinc-200 px-4 py-3 mb-6">
							<code class="text-sm text-zinc-700 flex-1 font-mono">
								{installCmd}
							</code>
						</div>
					</section>

					<a
						href={`https://www.npmjs.com/package/${entry.package}`}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center rounded-lg bg-zinc-100 hover:bg-zinc-200 border border-zinc-200 text-zinc-700 text-sm font-medium px-4 py-2 transition-colors no-underline"
					>
						View on npm
					</a>
				</>
			)}
		</div>
	</main>
</MarketingLayout>
