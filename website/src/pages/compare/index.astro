---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { compareEntries } from '@/data/compare';
import { jsonLdString } from '@/lib/jsonLd';

const title = 'Rivet vs Alternatives';
const description =
	'See how Rivet compares with alternative platforms for stateful backends, realtime applications, and durable workflows. Honest feature-by-feature breakdowns.';
const canonicalUrl = 'https://rivet.dev/compare/';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Compare', url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: title,
	description,
	url: canonicalUrl,
	isPartOf: { '@id': 'https://rivet.dev/#website' },
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: compareEntries.map((entry, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: entry.title,
			url: `https://rivet.dev/compare/${entry.slug}/`,
		})),
	},
};
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
	<script type="application/ld+json" set:html={jsonLdString(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={jsonLdString(collectionSchema)} />
	<div class="min-h-screen bg-black font-sans text-zinc-300 selection:bg-[#FF4500]/30 selection:text-orange-200">
		<main>
			<section class="relative flex flex-col justify-center px-6 pt-32 pb-16">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h1 class="mb-6 text-4xl font-normal leading-[1.1] tracking-tight text-white md:text-6xl">
							Rivet vs Alternatives
						</h1>
						<p class="text-base leading-relaxed text-zinc-500 md:text-lg">
							Honest comparisons between Rivet and other platforms for stateful backends,
							realtime applications, and durable workflows. Each page breaks down features,
							trade-offs, and when to choose each option.
						</p>
					</div>
				</div>
			</section>
			<section class="px-6 pb-32">
				<div class="mx-auto w-full max-w-7xl">
					<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
						{
							compareEntries.map((entry) => (
								<a
									href={`/compare/${entry.slug}/`}
									class="group flex flex-col rounded-lg border border-white/10 p-6 transition-colors hover:border-white/20 hover:bg-white/5"
								>
									<h2 class="mb-2 text-lg font-normal text-white">{entry.title}</h2>
									<p class="text-sm leading-relaxed text-zinc-500">{entry.description}</p>
									<span class="mt-4 text-sm text-zinc-300 transition-colors group-hover:text-white">
										Read the comparison
									</span>
								</a>
							))
						}
					</div>
				</div>
			</section>
		</main>
	</div>
</MarketingLayout>
