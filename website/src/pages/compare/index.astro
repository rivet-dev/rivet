---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { compareEntries } from '@/data/compare';
import { jsonLdString } from '@/lib/jsonLd';

const title = 'Rivet vs Alternatives';
const description =
	'See how Rivet compares with alternative platforms for stateful backends, realtime applications, and durable workflows. Honest feature-by-feature breakdowns.';
const canonicalUrl = 'https://rivet.dev/compare/';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Compare', url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: title,
	description,
	url: canonicalUrl,
	isPartOf: { '@id': 'https://rivet.dev/#website' },
	mainEntity: {
		'@type': 'ItemList',
		itemListElement: compareEntries.map((entry, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: entry.title,
			url: `https://rivet.dev/compare/${entry.slug}/`,
		})),
	},
};
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
	<script type="application/ld+json" set:html={jsonLdString(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={jsonLdString(collectionSchema)} />
	<div class="min-h-screen bg-black font-sans text-zinc-300 selection:bg-[#FF4500]/30 selection:text-orange-200">
		<main>
			<section class="px-6 pb-20 pt-32 md:pt-44">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h1 class="text-4xl font-medium leading-[1.06] tracking-[-0.015em] text-white md:text-[3.75rem]">
							Rivet vs Alternatives
						</h1>
						<p class="mt-7 max-w-2xl text-lg leading-8 text-zinc-400">
							Honest comparisons between Rivet and other platforms for stateful backends,
							realtime applications, and durable workflows. Each page breaks down features,
							trade-offs, and when to choose each option.
						</p>
					</div>
				</div>
			</section>
			<section class="px-6 pb-36">
				<div class="mx-auto w-full max-w-7xl">
					<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
						{
							compareEntries.map((entry) => (
								<a
									href={`/compare/${entry.slug}/`}
									class="group flex flex-col rounded-xl border border-white/10 p-7 transition-colors hover:border-white/25"
								>
									<h2 class="text-base font-medium tracking-tight text-white">{entry.title}</h2>
									<p class="mt-2 text-sm leading-relaxed text-zinc-500">{entry.description}</p>
									<span class="mt-5 inline-flex items-center gap-2 text-sm text-zinc-400 transition-colors group-hover:text-white">
										Read the comparison
										<span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
									</span>
								</a>
							))
						}
					</div>
				</div>
			</section>
		</main>
	</div>
</MarketingLayout>
