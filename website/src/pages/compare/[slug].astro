---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import FaqJsonLd from '@/components/faq/FaqJsonLd.astro';
import { ComparePage } from '@/components/marketing/compare/ComparePage';
import { compareEntries, getCompareEntry } from '@/data/compare';

export async function getStaticPaths() {
	return compareEntries.map((entry) => ({
		params: { slug: entry.slug },
	}));
}

const { slug } = Astro.params;
// The island receives only the slug because CompareEntry contains JSX cell
// text that cannot be serialized across the island boundary; both this
// frontmatter and the island read the same registry.
const entry = getCompareEntry(slug);
if (!entry) {
	throw new Error(`Unknown compare slug: ${slug}`);
}

const canonicalUrl = `https://rivet.dev/compare/${entry.slug}/`;

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Compare', url: 'https://rivet.dev/compare/' },
		{ name: entry.title, url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const webPageSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: entry.title,
	description: entry.description,
	url: canonicalUrl,
	dateModified: entry.lastUpdated,
	isPartOf: { '@id': 'https://rivet.dev/#website' },
};
---

<MarketingLayout
	title={entry.title}
	description={entry.description}
	canonicalUrl={canonicalUrl}
	keywords={entry.keywords}
>
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
	<FaqJsonLd items={entry.faq} />
	<ComparePage slug={entry.slug} client:load />
</MarketingLayout>
