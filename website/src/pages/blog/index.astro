---
import { getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { formatTimestamp } from '@/lib/formatDate';
import { AUTHORS, CATEGORIES } from '@/lib/article';
import { getPostImage } from '@/lib/postImage';

type AuthorInfo = {
	name: string;
	role: string;
	avatar: ImageMetadata;
	socials?: { twitter?: string; github?: string; bluesky?: string };
	url?: string;
};
import { AuthorAvatar } from '@/components/AuthorAvatar';
import { Icon, faRss } from '@rivet-gg/icons';

const MONTHS = [
	'January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December',
];

const posts = await getCollection('posts');

// Blog posts for the main column
const blogPosts = posts
	.filter((post) => post.data.category !== 'changelog' && !post.data.unpublished)
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
	.map((post) => {
		const slug = post.id.replace(/\/page$/, '');
		const data = post.data as unknown as { title: string; description: string };
		return {
			...post,
			slug,
			image: getPostImage(post),
			author: AUTHORS[post.data.author] as AuthorInfo,
			category: { ...CATEGORIES[post.data.category], id: post.data.category },
			title: data.title,
			description: data.description,
		};
	});

// Changelog entries for the left calendar, grouped by month
const changelogPosts = posts
	.filter((post) => post.data.category === 'changelog' && !post.data.unpublished)
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
	.map((post) => {
		const slug = post.id.replace(/\/page$/, '');
		const data = post.data as unknown as { title: string };
		return { slug, title: data.title, published: post.data.published };
	});

const changelogMonths: { key: string; label: string; items: typeof changelogPosts }[] = [];
for (const entry of changelogPosts) {
	const d = entry.published;
	const key = `${d.getFullYear()}-${d.getMonth()}`;
	const label = `${MONTHS[d.getMonth()]} ${d.getFullYear()}`;
	const group = changelogMonths.at(-1);
	if (!group || group.key !== key) {
		changelogMonths.push({ key, label, items: [entry] });
	} else {
		group.items.push(entry);
	}
}
---

<BlogLayout title="Blog - Rivet">
	<div class="mx-auto mt-20 w-full max-w-7xl px-6 md:mt-32" style="--header-height: 5rem;">
		<div class="mt-8 flex w-full items-center justify-between">
			<h1 class="text-4xl font-normal leading-[1.1] tracking-tight text-white md:text-6xl">Blog</h1>
			<a
				href="/rss/feed.xml"
				class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-white/10 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-white/20 hover:text-white"
			>
				<Icon icon={faRss} />
				RSS Feed
			</a>
		</div>

		<div class="mt-12 flex flex-col gap-12 lg:grid lg:grid-cols-[16rem_minmax(0,1fr)] lg:items-start lg:gap-14">
			<!-- Changelog calendar -->
			<aside class="order-last lg:order-none">
				<div class="lg:sticky lg:top-header">
					<div class="flex items-center justify-between border-b border-white/10 pb-3">
						<h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-zinc-500">Changelog</h2>
						<a href="/changelog/" class="text-xs text-zinc-500 transition-colors hover:text-white">View all</a>
					</div>
					<div class="mt-5 max-h-[calc(100vh-9rem)] space-y-6 overflow-y-auto pr-1 lg:pb-4">
						{changelogMonths.map((month) => (
							<div>
								<p class="text-[0.7rem] font-semibold uppercase tracking-[0.1em] text-zinc-600">{month.label}</p>
								<ul class="mt-2">
									{month.items.map((item) => (
										<li>
											<a
												href={`/changelog/${item.slug}/`}
												class="group flex gap-3 rounded-md py-1.5 transition-colors"
											>
												<time
													datetime={item.published.toISOString()}
													class="w-6 shrink-0 pt-px text-right text-xs tabular-nums text-zinc-600 transition-colors group-hover:text-accent"
												>
													{item.published.getDate()}
												</time>
												<span class="text-sm leading-snug text-zinc-400 transition-colors group-hover:text-white">
													{item.title}
												</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			</aside>

			<!-- Blog posts -->
			<div class="order-first grid grid-cols-1 gap-6 lg:order-none">
				{blogPosts.map((article) => (
					<a href={`/blog/${article.slug}/`} class="size-full">
						<article class="flex size-full flex-col items-start justify-between rounded-md border border-white/10 p-4 transition-colors hover:border-white/20">
							<div class="w-full">
								{article.image && (
									<div class="relative w-full">
										<img
											src={article.image.src}
											alt={article.title}
											width={1200}
											height={600}
											class="aspect-[2/1] w-full rounded-md border border-white/10 object-cover"
											loading="lazy"
											decoding="async"
										/>
									</div>
								)}
								<div class="mt-4 flex items-center gap-x-3 text-xs">
									<time datetime={article.data.published.toISOString()} class="text-zinc-500">
										{formatTimestamp(article.data.published)}
									</time>
									<span class="rounded-full border border-white/10 px-2 py-0.5 text-xs text-zinc-400">{article.category.name}</span>
								</div>
								<div class="group relative">
									<h3 class="mt-2 text-xl font-normal leading-7 text-white">
										{article.title}
									</h3>
									<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-zinc-500">
										{article.description}
									</p>
								</div>
							</div>
							<div class="max-w-xl">
								<div class="relative mt-4 flex items-center gap-x-3">
									<AuthorAvatar name={article.author.name} avatarSrc={article.author.avatar.src} client:load />
									<div class="text-sm text-zinc-400">
										{article.author.name}
									</div>
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</div>
	</div>
</BlogLayout>
