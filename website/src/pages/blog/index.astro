---
import { getCollection } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { CATEGORIES } from '@/lib/article';
import { formatTimestamp } from '@/lib/formatDate';
import { getPostImage } from '@/lib/postImage';
import { Icon, faRss } from '@rivet-gg/icons';

const MONTHS = [
	'January', 'February', 'March', 'April', 'May', 'June',
	'July', 'August', 'September', 'October', 'November', 'December',
];

const posts = await getCollection('posts');

// Blog posts for the main column
const blogPosts = posts
	.filter((post) => post.data.category !== 'changelog' && !post.data.unpublished)
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
	.map((post) => {
		const slug = post.id.replace(/\/page$/, '');
		const data = post.data as unknown as { title: string; description: string };
		return {
			...post,
			slug,
			image: getPostImage(post),
			title: data.title,
			description: data.description,
		};
	});

// Changelog entries for the left calendar, grouped by month
const changelogPosts = posts
	.filter((post) => post.data.category === 'changelog' && !post.data.unpublished)
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
	.map((post) => {
		const slug = post.id.replace(/\/page$/, '');
		const data = post.data as unknown as { title: string };
		return { slug, title: data.title, published: post.data.published };
	});

const changelogMonths: { key: string; label: string; items: typeof changelogPosts }[] = [];
for (const entry of changelogPosts) {
	const d = entry.published;
	const key = `${d.getFullYear()}-${d.getMonth()}`;
	const label = `${MONTHS[d.getMonth()]} ${d.getFullYear()}`;
	const group = changelogMonths.at(-1);
	if (!group || group.key !== key) {
		changelogMonths.push({ key, label, items: [entry] });
	} else {
		group.items.push(entry);
	}
}
---

<BlogLayout title="Blog - Rivet">
	<div class="mx-auto w-full max-w-7xl px-6 pb-32 pt-20 md:pb-48 md:pt-32" style="--header-height: 5rem;">
		<div class="mt-8 flex w-full items-center justify-between">
			<h1 class="text-4xl font-medium leading-[1.06] tracking-[-0.015em] text-ink md:text-6xl">Blog</h1>
			<a
				href="/rss/feed.xml"
				class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-ink/20 px-4 py-2 text-sm text-ink-soft transition-colors hover:border-ink/40 hover:text-ink"
			>
				<Icon icon={faRss} />
				RSS Feed
			</a>
		</div>

		<div class="mt-12 flex flex-col gap-12 lg:grid lg:grid-cols-[16rem_minmax(0,1fr)] lg:gap-14">
			<!-- Changelog calendar -->
			<aside class="order-last lg:order-none">
				<div class="lg:sticky lg:top-32">
					<div class="border-b border-ink/10 pb-3">
						<h2 class="font-mono text-[11px] font-medium uppercase tracking-[0.16em] text-pine">Changelog</h2>
					</div>
					<div class="relative">
						<div class="mt-5 max-h-[calc(100vh-14rem)] space-y-6 overflow-y-auto pb-6 pr-1">
							{changelogMonths.map((month) => (
							<div>
								<p class="font-mono text-[0.7rem] font-medium uppercase tracking-[0.1em] text-ink-faint">{month.label}</p>
								<ul class="mt-2">
									{month.items.map((item) => (
										<li>
											<a
												href={`/changelog/${item.slug}/`}
												class="group flex gap-3 rounded-md py-1.5 transition-colors"
											>
												<time
													datetime={item.published.toISOString()}
													class="w-6 shrink-0 pt-px text-right font-mono text-xs tabular-nums text-ink-faint transition-colors group-hover:text-pine"
												>
													{item.published.getDate()}
												</time>
												<span class="text-sm leading-snug text-ink-soft transition-colors group-hover:text-ink">
													{item.title}
												</span>
											</a>
										</li>
									))}
								</ul>
							</div>
						))}
						</div>
						<div class="pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-paper to-transparent"></div>
					</div>
				</div>
			</aside>

			<!-- Blog posts -->
			<div class="order-first grid grid-cols-1 gap-6 md:grid-cols-2 lg:order-none">
				{blogPosts.map((article) => (
					<a href={`/blog/${article.slug}/`} class="size-full">
						<article class="flex size-full flex-col items-start justify-between border border-ink/10 bg-white/55 p-4 transition-colors hover:border-ink/25">
							<div class="w-full">
								{article.image && (
									<div class="relative w-full">
										<img
											src={article.image.src}
											alt={article.title}
											width={1200}
											height={600}
											class="aspect-[2/1] w-full rounded-md border border-ink/10 object-cover"
											loading="lazy"
											decoding="async"
										/>
									</div>
								)}
								<div class="mt-4 flex items-center gap-x-3 text-xs">
									{CATEGORIES[article.data.category] && (
										<span class="font-medium uppercase tracking-[0.1em] text-pine">
											{CATEGORIES[article.data.category].name}
										</span>
									)}
									<time datetime={article.data.published.toISOString()} class="text-ink-faint">
										{formatTimestamp(article.data.published)}
									</time>
								</div>
								<div class="group relative">
									<h3 class="mt-2 text-xl font-medium leading-7 text-ink">
										{article.title}
									</h3>
									<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-ink-soft">
										{article.description}
									</p>
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</div>
	</div>
</BlogLayout>
