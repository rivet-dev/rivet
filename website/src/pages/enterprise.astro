---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { jsonLdString } from '@/lib/jsonLd';

const title = 'Rivet Enterprise';
const description =
	'Run Rivet on-prem, in your VPC, embedded in your customers’ environments, or fully air-gapped. A single binary you control, with no outbound telemetry.';
const canonicalUrl = 'https://rivet.dev/enterprise/';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Enterprise', url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const deploymentModels = [
	{
		title: 'Your VPC',
		body: 'Run the same Rivet that powers our cloud as a single binary inside your perimeter. No outbound calls, no telemetry leaving your boundary.',
	},
	{
		title: 'Embedded in your customers',
		body: 'Ship Rivet inside your customer’s VPC, regulated environment, or on-prem hardware. They keep their data, you keep your product.',
	},
	{
		title: 'Air-gapped',
		body: 'Deploy on networks with no internet access. Everything Rivet needs ships in the artifact you install, so disconnected environments run the full platform.',
	},
];
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
	<script type="application/ld+json" set:html={jsonLdString(breadcrumbSchema)} />
	<div class="min-h-screen bg-black font-sans text-zinc-300 selection:bg-[#FF4500]/30 selection:text-orange-200">
		<main>
			<!-- Hero -->
			<section class="px-6 pb-20 pt-32 md:pt-44">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h1 class="text-4xl font-medium leading-[1.06] tracking-[-0.015em] text-white md:text-6xl">
							Run Rivet inside your perimeter.
						</h1>
						<p class="mt-4 text-base leading-relaxed text-zinc-500 md:text-lg">
							Deploy Rivet in your VPC, embed it in your customers’ environments, or run it
							fully air-gapped. The same platform that powers Rivet Cloud, under your control.
						</p>
						<div class="mt-8 flex flex-col gap-3 sm:flex-row">
							<a
								href="/talk-to-an-engineer"
								class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-white px-4 py-2 text-sm font-medium text-black transition-colors hover:bg-zinc-200"
							>
								Talk to an engineer
							</a>
							<a
								href="/docs/self-hosting"
								class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-white/10 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-white/20 hover:text-white"
							>
								Read self-hosting docs
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- Deployment models -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
							Three ways to deploy.
						</h2>
						<p class="mt-4 text-base leading-relaxed text-zinc-500">
							Rivet ships as software you run, not a service you call out to. Pick the
							boundary, and Rivet stays inside it.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						{
							deploymentModels.map((model) => (
								<div class="flex flex-col rounded-xl border border-white/10 p-7">
									<h3 class="text-base font-medium text-white">{model.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-zinc-500">{model.body}</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Compliance posture -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="rounded-xl border border-white/15 bg-white/[0.03] p-8 md:p-12">
						<div class="max-w-3xl">
							<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
								Your compliance posture, intact.
							</h2>
							<p class="mt-4 text-base leading-relaxed text-zinc-500">
								Deploy inside the boundary your existing controls already cover. FedRAMP,
								HIPAA, and sovereign-cloud environments stay within your audit story because
								nothing leaves your perimeter. No new data processor to assess, no new
								subprocessor to disclose, no waiting on a vendor’s certification roadmap.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Architecture footprint -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
							A footprint your ops team will sign off on.
						</h2>
						<p class="mt-4 text-base leading-relaxed text-zinc-500">
							Rivet self-hosts as a single binary or a Docker Compose file, and scales to
							Kubernetes when you need it. Most platforms in this space either require a
							multi-service cluster before you can evaluate them or only run on the vendor’s
							own cloud. Rivet starts as one process on one machine and grows with your
							deployment, so a proof of concept takes an afternoon instead of a quarter.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						<div class="flex flex-col rounded-xl border border-white/10 p-7">
							<h3 class="text-base font-medium text-white">Single binary</h3>
							<p class="mt-2 text-sm leading-relaxed text-zinc-500">
								One process to install, monitor, and upgrade. Ideal for evaluation,
								embedded deployments, and air-gapped installs.
							</p>
						</div>
						<div class="flex flex-col rounded-xl border border-white/10 p-7">
							<h3 class="text-base font-medium text-white">Docker Compose</h3>
							<p class="mt-2 text-sm leading-relaxed text-zinc-500">
								A complete environment in one file. Stand up Rivet alongside your existing
								services without changing how you operate them.
							</p>
						</div>
						<div class="flex flex-col rounded-xl border border-white/10 p-7">
							<h3 class="text-base font-medium text-white">Kubernetes</h3>
							<p class="mt-2 text-sm leading-relaxed text-zinc-500">
								Scale out across nodes and regions when traffic demands it. The same
								artifact you evaluated runs in production.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Closing CTA -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl text-center">
					<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
						Bring Rivet inside your boundary.
					</h2>
					<p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-zinc-500">
						Walk through your deployment model with an engineer, or start with the
						self-hosting docs and run it yourself.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
						<a
							href="/talk-to-an-engineer"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-white px-4 py-2 text-sm font-medium text-black transition-colors hover:bg-zinc-200"
						>
							Talk to an engineer
						</a>
						<a
							href="/docs/self-hosting"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-white/10 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-white/20 hover:text-white"
						>
							Read self-hosting docs
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</MarketingLayout>
