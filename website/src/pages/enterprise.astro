---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { jsonLdString } from '@/lib/jsonLd';
import { PerimeterDiagram } from '@/components/marketing/editorial/PerimeterDiagram';
import { CatalogCard } from '@/components/marketing/editorial/CatalogCard';
import { HERO_H1_CLASS, SECTION_H2_CLASS, SUBTITLE_CLASS } from '@/components/marketing/typography';

const title = 'Rivet Enterprise';
const description =
	'Run Rivet on-prem, in your VPC, embedded in your customers’ environments, or fully air-gapped. A single binary you control, with no outbound telemetry.';
const canonicalUrl = 'https://rivet.dev/enterprise/';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Enterprise', url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const deploymentModels = [
	{
		index: '01',
		title: 'Your VPC',
		body: 'Run the same Rivet that powers our cloud as a single binary inside your perimeter. No outbound calls, no telemetry leaving your boundary.',
	},
	{
		index: '02',
		title: 'Embedded in your customers',
		body: 'Ship Rivet inside your customer’s VPC, regulated environment, or on-prem hardware. They keep their data, you keep your product.',
	},
	{
		index: '03',
		title: 'Air-gapped',
		body: 'Deploy on networks with no internet access. Everything Rivet needs ships in the artifact you install, so disconnected environments run the full platform.',
	},
];

const guarantees = [
	'No outbound connections required',
	'No telemetry by default',
	'Your data never leaves your boundary',
	'Air-gapped installs supported',
	'No new subprocessor to disclose',
];

const footprints = [
	{
		title: 'Single binary',
		body: 'One process to install, monitor, and upgrade. Ideal for evaluation, embedded deployments, and air-gapped installs.',
	},
	{
		title: 'Docker Compose',
		body: 'A complete environment in one file. Stand up Rivet alongside your existing services without changing how you operate them.',
	},
	{
		title: 'Kubernetes',
		body: 'Scale out across nodes and regions when traffic demands it. The same artifact you evaluated runs in production.',
	},
];

const enterpriseEditionFeatures = [
	'Actor orchestration engine',
	'FoundationDB persistence layer',
	'Cloud layer for multi-tenant',
	'SQLite backup',
	'SQLite PITR',
	'Forking',
	'ACL system',
	'ACL for agents',
	'Advanced ClickHouse analytics',
	'OpenTelemetry integration',
	'Alert manager rules, Prometheus rules, Grafana configs',
	'Kubernetes manifests',
	'Air-gapped & sovereign-cloud deployments',
	'Priority support & SLA',
	'Hardening guidance for FedRAMP, HIPAA, and regulated industries',
];
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
	<script type="application/ld+json" set:html={jsonLdString(breadcrumbSchema)} />
	<div class="paper-grain min-h-screen font-sans text-ink-soft">
		<main>
			<!-- Hero -->
			<section class="px-6 pb-20 pt-32 md:pb-28 md:pt-44">
				<div class="mx-auto w-full max-w-7xl">
					<div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">
						<div>
							<h1 class={HERO_H1_CLASS}>Run Rivet inside your perimeter.</h1>
							<p class="mt-4 max-w-xl text-base leading-relaxed text-ink-soft md:text-lg">
								Deploy Rivet in your VPC, embed it in your customers’ environments, or run it
								fully air-gapped. The same platform that powers Rivet Cloud, under your control.
							</p>
							<div class="mt-8 flex flex-col gap-3 sm:flex-row">
								<a
									href="/talk-to-an-engineer"
									class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-accent-deep px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent"
								>
									Talk to an engineer
								</a>
								<a
									href="/docs/self-hosting"
									class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-ink/20 px-4 py-2 text-sm text-ink-soft transition-colors hover:border-ink/40 hover:text-ink"
								>
									Read self-hosting docs
								</a>
							</div>
						</div>
						<PerimeterDiagram />
					</div>
				</div>
			</section>

			<!-- Deployment models -->
			<section class="border-t border-ink/10 px-6 py-16 md:py-32">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class={SECTION_H2_CLASS}>Three ways to deploy.</h2>
						<p class={SUBTITLE_CLASS}>
							Rivet ships as software you run, not a service you call out to. Pick the
							boundary, and Rivet stays inside it.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						{
							deploymentModels.map((model) => (
								<CatalogCard title={model.title}>
									<p class="mt-2 text-sm leading-relaxed text-ink-soft">{model.body}</p>
								</CatalogCard>
							))
						}
					</div>
				</div>
			</section>

			<!-- Enterprise Edition contents -->
			<section class="border-t border-ink/10 px-6 py-16 md:py-32">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class={SECTION_H2_CLASS}>Everything in Enterprise Edition.</h2>
						<p class={SUBTITLE_CLASS}>
							Closed-source, production-grade features on top of the open-source engine. The
							orchestration, multi-tenancy, and compliance layer to run Rivet at enterprise scale,
							in your own VPC, customer environments, or regulated networks.
						</p>
					</div>
					<ul class="mt-12 grid grid-cols-1 gap-x-8 gap-y-4 sm:grid-cols-2 lg:grid-cols-3">
						{
							enterpriseEditionFeatures.map((feature) => (
								<li class="flex items-start gap-3 text-sm leading-relaxed text-ink-soft">
									<span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full border border-pine/30">
										<svg class="h-3 w-3 text-pine" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
											<path d="M20 6 9 17l-5-5" />
										</svg>
									</span>
									{feature}
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- Compliance posture -->
			<section class="border-y border-ink/10 bg-paper-deep/40 px-6 py-16 md:py-32">
				<div class="mx-auto w-full max-w-7xl">
					<div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
						<div>
							<h2 class={SECTION_H2_CLASS}>Your compliance posture, intact.</h2>
							<p class={SUBTITLE_CLASS}>
								Deploy inside the boundary your existing controls already cover. FedRAMP,
								HIPAA, and sovereign-cloud environments stay within your audit story because
								nothing leaves your perimeter. No new data processor to assess, no waiting
								on a vendor’s certification roadmap.
							</p>
						</div>
						<ul class="space-y-4">
							{
								guarantees.map((item) => (
									<li class="flex items-start gap-3 text-sm leading-relaxed text-ink-soft">
										<span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full border border-pine/30">
											<svg class="h-3 w-3 text-pine" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
												<path d="M20 6 9 17l-5-5" />
											</svg>
										</span>
										{item}
									</li>
								))
							}
						</ul>
					</div>
				</div>
			</section>

			<!-- Architecture footprint -->
			<section class="px-6 py-16 md:py-32">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class={SECTION_H2_CLASS}>A footprint your ops team will sign off on.</h2>
						<p class={SUBTITLE_CLASS}>
							Rivet self-hosts as a single binary or a Docker Compose file, and scales to
							Kubernetes when you need it. Most platforms in this space either require a
							multi-service cluster before you can evaluate them or only run on the vendor’s
							own cloud. Rivet starts as one process on one machine and grows with your
							deployment, so a proof of concept takes an afternoon instead of a quarter.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						{
							footprints.map((fp) => (
								<div class="flex flex-col rounded-xl border border-ink/10 bg-white/55 p-7 transition-colors hover:border-ink/25">
									<h3 class="text-base font-medium text-ink">{fp.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-ink-soft">{fp.body}</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Closing CTA -->
			<section class="border-t border-ink/10 px-6 py-16 md:py-32">
				<div class="mx-auto w-full max-w-7xl text-center">
					<h2 class={SECTION_H2_CLASS}>Bring Rivet inside your boundary.</h2>
					<p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-ink-soft">
						Walk through your deployment model with an engineer, or start with the
						self-hosting docs and run it yourself.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
						<a
							href="/talk-to-an-engineer"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-ink px-4 py-2 text-sm font-medium text-cream transition-colors hover:bg-ink/85"
						>
							Talk to an engineer
						</a>
						<a
							href="/docs/self-hosting"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-ink/20 px-4 py-2 text-sm text-ink-soft transition-colors hover:border-ink/40 hover:text-ink"
						>
							Read self-hosting docs
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</MarketingLayout>
