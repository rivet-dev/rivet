---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { jsonLdString } from '@/lib/jsonLd';

const title = 'Rivet Enterprise';
const description =
	'Run Rivet on-prem, in your VPC, embedded in your customers’ environments, or fully air-gapped. A single binary you control, with no outbound telemetry.';
const canonicalUrl = 'https://rivet.dev/enterprise/';

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ name: 'Home', url: 'https://rivet.dev/' },
		{ name: 'Enterprise', url: canonicalUrl },
	].map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};

const deploymentModels = [
	{
		index: '01',
		title: 'Your VPC',
		body: 'Run the same Rivet that powers our cloud as a single binary inside your perimeter. No outbound calls, no telemetry leaving your boundary.',
	},
	{
		index: '02',
		title: 'Embedded in your customers',
		body: 'Ship Rivet inside your customer’s VPC, regulated environment, or on-prem hardware. They keep their data, you keep your product.',
	},
	{
		index: '03',
		title: 'Air-gapped',
		body: 'Deploy on networks with no internet access. Everything Rivet needs ships in the artifact you install, so disconnected environments run the full platform.',
	},
];

const diagramNodes = [
	{ title: 'Your backend', detail: 'Actors run in your Node.js or Bun process' },
	{ title: 'Rivet Engine', detail: 'Single binary for orchestration and routing' },
	{ title: 'Your storage', detail: 'File system, Postgres, or FoundationDB' },
];

const guarantees = [
	'No outbound connections required',
	'No telemetry by default',
	'Your data never leaves your boundary',
	'Air-gapped installs supported',
	'No new subprocessor to disclose',
];

const footprints = [
	{
		label: 'single-binary',
		title: 'Single binary',
		body: 'One process to install, monitor, and upgrade. Ideal for evaluation, embedded deployments, and air-gapped installs.',
	},
	{
		label: 'docker-compose.yml',
		title: 'Docker Compose',
		body: 'A complete environment in one file. Stand up Rivet alongside your existing services without changing how you operate them.',
	},
	{
		label: 'kubernetes',
		title: 'Kubernetes',
		body: 'Scale out across nodes and regions when traffic demands it. The same artifact you evaluated runs in production.',
	},
];
---

<MarketingLayout title={title} description={description} canonicalUrl={canonicalUrl}>
	<script type="application/ld+json" set:html={jsonLdString(breadcrumbSchema)} />
	<div class="min-h-screen bg-black font-sans text-zinc-300 selection:bg-[#FF4500]/30 selection:text-orange-200">
		<main>
			<!-- Hero -->
			<section class="px-6 pb-20 pt-32 md:pb-28 md:pt-44">
				<div class="mx-auto w-full max-w-7xl">
					<div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">
						<div>
							<h1 class="text-4xl font-medium leading-[1.06] tracking-[-0.015em] text-white md:text-6xl">
								Run Rivet inside your perimeter.
							</h1>
							<p class="mt-4 max-w-xl text-base leading-relaxed text-zinc-500 md:text-lg">
								Deploy Rivet in your VPC, embed it in your customers’ environments, or run it
								fully air-gapped. The same platform that powers Rivet Cloud, under your control.
							</p>
							<div class="mt-8 flex flex-col gap-3 sm:flex-row">
								<a
									href="/talk-to-an-engineer"
									class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-white px-4 py-2 text-sm font-medium text-black transition-colors hover:bg-zinc-200"
								>
									Talk to an engineer
								</a>
								<a
									href="/docs/self-hosting"
									class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-white/10 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-white/20 hover:text-white"
								>
									Read self-hosting docs
								</a>
							</div>
						</div>
						<div class="relative rounded-xl border border-dashed border-white/20 p-6 md:p-8">
							<span class="absolute -top-2.5 left-6 bg-black px-2 font-mono text-[11px] uppercase tracking-wider text-zinc-500">
								Your perimeter
							</span>
							<div class="flex flex-col items-stretch">
								{
									diagramNodes.map((node, idx) => (
										<div class="flex flex-col">
											{idx > 0 && <div class="mx-auto h-5 w-px bg-white/15" />}
											<div class="rounded-lg border border-white/10 bg-white/[0.03] px-4 py-3">
												<div class="text-sm font-medium text-white">{node.title}</div>
												<div class="mt-0.5 text-xs text-zinc-500">{node.detail}</div>
											</div>
										</div>
									))
								}
							</div>
							<div class="mt-6 flex items-center gap-2 border-t border-white/10 pt-4 font-mono text-[11px] text-zinc-500">
								<svg class="h-3.5 w-3.5 text-zinc-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
									<circle cx="12" cy="12" r="10" />
									<path d="m4.9 4.9 14.2 14.2" />
								</svg>
								No outbound connections. No telemetry.
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Deployment models -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
							Three ways to deploy.
						</h2>
						<p class="mt-4 text-base leading-relaxed text-zinc-500">
							Rivet ships as software you run, not a service you call out to. Pick the
							boundary, and Rivet stays inside it.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						{
							deploymentModels.map((model) => (
								<div class="flex flex-col rounded-xl border border-white/10 p-7 transition-colors hover:border-white/25">
									<span class="font-mono text-[11px] text-zinc-600">{model.index}</span>
									<h3 class="mt-3 text-base font-medium text-white">{model.title}</h3>
									<p class="mt-2 text-sm leading-relaxed text-zinc-500">{model.body}</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Compliance posture -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="rounded-xl border border-white/15 bg-white/[0.03] p-8 md:p-12">
						<div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
							<div>
								<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
									Your compliance posture, intact.
								</h2>
								<p class="mt-4 text-base leading-relaxed text-zinc-500">
									Deploy inside the boundary your existing controls already cover. FedRAMP,
									HIPAA, and sovereign-cloud environments stay within your audit story because
									nothing leaves your perimeter. No new data processor to assess, no waiting
									on a vendor’s certification roadmap.
								</p>
							</div>
							<ul class="space-y-4">
								{
									guarantees.map((item) => (
										<li class="flex items-start gap-3 text-sm leading-relaxed text-zinc-300">
											<span class="mt-0.5 flex h-5 w-5 flex-none items-center justify-center rounded-full border border-white/10 bg-white/5">
												<svg class="h-3 w-3 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
													<path d="M20 6 9 17l-5-5" />
												</svg>
											</span>
											{item}
										</li>
									))
								}
							</ul>
						</div>
					</div>
				</div>
			</section>

			<!-- Architecture footprint -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl">
					<div class="max-w-3xl">
						<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
							A footprint your ops team will sign off on.
						</h2>
						<p class="mt-4 text-base leading-relaxed text-zinc-500">
							Rivet self-hosts as a single binary or a Docker Compose file, and scales to
							Kubernetes when you need it. Most platforms in this space either require a
							multi-service cluster before you can evaluate them or only run on the vendor’s
							own cloud. Rivet starts as one process on one machine and grows with your
							deployment, so a proof of concept takes an afternoon instead of a quarter.
						</p>
					</div>
					<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
						{
							footprints.map((fp) => (
								<div class="flex flex-col rounded-xl border border-white/10 transition-colors hover:border-white/25">
									<div class="border-b border-white/10 px-7 py-3 font-mono text-[11px] text-zinc-500">
										{fp.label}
									</div>
									<div class="p-7 pt-5">
										<h3 class="text-base font-medium text-white">{fp.title}</h3>
										<p class="mt-2 text-sm leading-relaxed text-zinc-500">{fp.body}</p>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Closing CTA -->
			<section class="border-t border-white/10 px-6 py-20 md:py-28">
				<div class="mx-auto w-full max-w-7xl text-center">
					<h2 class="text-3xl font-medium tracking-[-0.015em] text-white md:text-4xl">
						Bring Rivet inside your boundary.
					</h2>
					<p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-zinc-500">
						Walk through your deployment model with an engineer, or start with the
						self-hosting docs and run it yourself.
					</p>
					<div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
						<a
							href="/talk-to-an-engineer"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-white px-4 py-2 text-sm font-medium text-black transition-colors hover:bg-zinc-200"
						>
							Talk to an engineer
						</a>
						<a
							href="/docs/self-hosting"
							class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-white/10 px-4 py-2 text-sm text-zinc-300 transition-colors hover:border-white/20 hover:text-white"
						>
							Read self-hosting docs
						</a>
					</div>
				</div>
			</section>
		</main>
	</div>
</MarketingLayout>
