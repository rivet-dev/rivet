{
	"$schema": "https://turbo.build/schema.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["VITE_APP_*", "VITE_FEATURE_FLAGS", "DEPLOYMENT_TYPE"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"env": ["VITE_APP_*", "VITE_FEATURE_FLAGS"],
			"persistent": true
		}
	}
}
