{
	"name": "@rivetkit/engine-test-runner",
	"version": "2.1.10",
	"type": "module",
	"rivetkit": {
		".": "src/index.ts"
	},
	"scripts": {
		"start": "tsx src/index.ts",
		"build": "tsup src/index.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.1",
		"@rivetkit/engine-runner": "workspace:*",
		"@rivetkit/engine-runner-protocol": "workspace:*",
		"hono": "^4.7.0",
		"pino": "^9.9.5",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@types/node": "^22.18.1",
		"@types/ws": "^8.18.1",
		"tinybench": "^5.0.1",
		"tsup": "^8.5.0",
		"tsx": "^4.20.5",
		"typescript": "^5.9.2",
		"vitest": "^1.6.1"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/types/index.d.ts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"files": [
		"dist",
		"src",
		"package.json"
	]
}
