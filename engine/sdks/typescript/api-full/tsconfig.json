{
	"compilerOptions": {
		"extendedDiagnostics": true,
		"strict": true,
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["node"],
		"declaration": true,
		"emitDeclarationOnly": true,
		"sourceMap": true,
		"noUnusedParameters": true,
		"outDir": "types",
		"rootDir": "src",
		"baseUrl": "src",
		"paths": {
			"@rivetkit/engine-api": ["."]
		}
	},
	"ts-expect-error-comments": false,
	"include": ["src"],
	"exclude": []
}
