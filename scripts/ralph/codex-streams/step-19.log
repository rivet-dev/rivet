) => Promise<TRow[]>;

export type RawAccess = {
	/**
	 * Executes a raw SQL query.
	 */
	execute: ExecuteFunction;
	/**
	 * Closes the database connection and releases resources.
	 */
	close: () => Promise<void>;
};

