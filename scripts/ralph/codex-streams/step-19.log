			actions,
			on_before_action_response: optional_tsfn(
				&callbacks,
				"onBeforeActionResponse",
				build_before_action_response_payload,
			)?,
			run: optional_tsfn(&callbacks, "run", build_lifecycle_payload)?,
		})
	}

