			TEvents,
			TQueues
		>,
		websocket: UniversalWebSocket,
	) => void | Promise<void>;

	actions?: TActions;

	/**
	 * Schema map for events broadcasted by this actor.
	 */
	events?: TEvents;

	/**
	 * Schema map for queue payloads sent by this actor.
	 */
	queues?: TQueues;
}

