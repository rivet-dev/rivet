						const { ctx, newState } = unwrapTsfnPayload(error, payload);
						const actorCtx = new NativeActorContextAdapter(
							ctx,
							createClient,
							schemaConfig,
						);
						try {
							await config.onStateChange(actorCtx, decodeValue(newState));
						} finally {
							await actorCtx.dispose();
						}
					})
				: undefined,
		onBeforeConnect:
