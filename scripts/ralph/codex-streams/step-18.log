+			let error = RivetError::extract(&error);
+
+			assert_eq!(error.group(), "actor");
+			assert_eq!(error.code(), "validation_error");
+			assert!(
+				error.message().contains("actor state"),
+				"unexpected error message: {}",
+				error.message(),
+			);
+		}
 	}
