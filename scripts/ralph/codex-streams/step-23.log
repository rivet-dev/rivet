use super::*;

pub(crate) fn new_with_kv(
	actor_id: impl Into<String>,
	name: impl Into<String>,
	key: ActorKey,
	region: impl Into<String>,
	kv: crate::kv::Kv,
) -> ActorContext {
	ActorContext::build(
		actor_id.into(),
		name.into(),
		key,
		region.into(),
		ActorConfig::default(),
		kv,
		SqliteDb::default(),
	)
}

