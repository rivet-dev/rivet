	active_queue_wait_count: AtomicU32,
	wait_activity_callback: StdMutex<Option<Arc<dyn Fn() + Send + Sync>>>,
	metrics: ActorMetrics,
}

#[derive(Clone, Debug)]
pub struct QueueMessage {
