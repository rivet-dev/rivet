+}
+
+type StateRequest struct {
+	id: uint
+}
+
+type ConnectionsRequest struct {
+	id: uint
+}
+
+type RpcsListRequest struct {
+	id: uint
+}
+
+type TraceQueryRequest struct {
+	id: uint
+	startMs: uint
+	endMs: uint
+	limit: uint
+}
+
+type QueueRequest struct {
+	id: uint
