+}
+
+type EventsUpdated struct {
+	events: list<Event>
+}
+
+type RpcsListResponse struct {
+	rid: uint
+	rpcs: list<str>
+}
+
+type Error struct {
+	message: str
+}
+
+type ToClientBody union {
+	StateResponse |
+	ConnectionsResponse |
+	EventsResponse |
+	ActionResponse |
+	RpcsListResponse |
+	ConnectionsUpdated |
+	EventsUpdated |
+	StateUpdated |
+	Error |
+	Init
+}
+
+type ConnectionsUpdated struct {
+	connections: list<Connection>
+}
+
+type ToClient struct {
+	body: ToClientBody
+}
