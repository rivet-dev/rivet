+	name: str
+	args: data
+	connId: str
+}
+
+type BroadcastEvent struct {
+	eventName: str
+	args: data
+}
+
+type SubscribeEvent struct {
+	eventName: str
+	connId: str
+}
+
+type UnSubscribeEvent struct {
+	eventName: str
+	connId: str
+}
+
+type FiredEvent struct {
+	eventName: str
+	args: data
+	connId: str
+}
+
+type EventBody union {
+	ActionEvent |
+	BroadcastEvent |
+	SubscribeEvent |
+	UnSubscribeEvent |
+	FiredEvent
+}
+
+type Event struct {
+	body: EventBody
+}
+
+type Init struct {
+	connections: list<Connection>
