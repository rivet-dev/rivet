+}
+
+type Error struct {
+	message: str
+}
+
+type ToClientBody union {
+	StateResponse |
+	ConnectionsResponse |
+	ActionResponse |
+	ConnectionsUpdated |
+	QueueUpdated |
+	StateUpdated |
+	WorkflowHistoryUpdated |
+	RpcsListResponse |
+	TraceQueryResponse |
+	QueueResponse |
+	WorkflowHistoryResponse |
+	Error |
+	Init |
+	DatabaseSchemaResponse |
+	DatabaseTableRowsResponse
+}
+
+type ToClient struct {
+	body: ToClientBody
+}
