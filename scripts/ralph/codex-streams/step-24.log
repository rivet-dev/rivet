+}
+
+type ToServerBody union {
+	PatchStateRequest |
+	StateRequest |
+	ConnectionsRequest |
+	ActionRequest |
+	RpcsListRequest |
+	TraceQueryRequest |
+	QueueRequest |
+	WorkflowHistoryRequest |
+	WorkflowReplayRequest |
+	DatabaseSchemaRequest |
+	DatabaseTableRowsRequest
+}
+
+type ToServer struct {
+	body: ToServerBody
+}
+
+type Connection struct {
