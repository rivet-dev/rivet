+	id: uint
+}
+
+type ClearEventsRequest struct {
+	id: uint
+}
+
+type RpcsListRequest struct {
+	id: uint
+}
+
+type ToServerBody union {
+	PatchStateRequest |
+	StateRequest |
+	ConnectionsRequest |
+	ActionRequest |
+	EventsRequest |
+	ClearEventsRequest |
+	RpcsListRequest
+}
+
+type ToServer struct {
+	body: ToServerBody
+}
+
