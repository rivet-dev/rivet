+	ConnectionsResponse |
+	EventsResponse |
+	ActionResponse |
+	RpcsListResponse |
+	ConnectionsUpdated |
+	EventsUpdated |
+	StateUpdated |
+	Error |
+	Init
+}
+
+type ConnectionsUpdated struct {
