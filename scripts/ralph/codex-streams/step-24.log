+}
+
+type UnSubscribeEvent struct {
+	eventName: str
+	connId: str
+}
+
+type FiredEvent struct {
+	eventName: str
+	args: data
+	connId: str
+}
+
+type EventBody union {
+	ActionEvent |
+	BroadcastEvent |
+	SubscribeEvent |
+	UnSubscribeEvent |
+	FiredEvent
