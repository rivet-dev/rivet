-								})
-								.catch((error) => {
-									logger().error({
-										msg: "failed to convert blob to arraybuffer",
-										error,
-									});
-								});
-						} else {
-							logger().debug({
-								msg: "sending client data directly to server",
-								dataType: typeof clientEvt.data,
-								dataLength:
-									typeof clientEvt.data === "string"
-										? clientEvt.data.length
-										: undefined,
-							});
