-
-				// Transform ActorOutput to match ActorSchema
-				const actor = createApiActor(actorOutput);
-
-				return c.json<ActorsCreateResponse>({ actor });
-			});
-		}
-
-		// GET /actors/{actor_id}/kv/keys/{key}
-		{
-			const route = createRoute({
-				method: "get",
