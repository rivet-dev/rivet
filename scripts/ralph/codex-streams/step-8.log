-function stripRvtQueryParams(rawQuery: string): string {
-	const actorParts = rawQuery.split("&").filter((part) => {
-		if (part.length === 0) return false;
-		const key = part.split("=")[0];
-		return !key.startsWith(RVT_PREFIX);
-	});
