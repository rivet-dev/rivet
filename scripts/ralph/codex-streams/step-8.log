-export function normalizeEndpointUrl(url: string): string | null {
-	try {
-		const parsed = new URL(url);
-		// Normalize pathname by removing trailing slash (except for root)
-		const pathname =
-			parsed.pathname === "/" ? "/" : parsed.pathname.replace(/\/+$/, "");
