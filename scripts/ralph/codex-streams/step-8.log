-	let remainingBase: string;
-	if (prefixLen < basePath.length) {
-		remainingBase = basePath.slice(prefixLen);
-	} else {
-		remainingBase = "/";
-	}
-
-	if (remainingBase.length === 0 || !remainingBase.startsWith("/")) {
-		return `/${remainingBase}${queryString}`;
-	}
-
-	return `${remainingBase}${queryString}`;
-}
