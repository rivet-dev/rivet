-/**
- * Handle path-based HTTP routing
- */
-async function handleHttpGatewayPathBased(
-	config: RegistryConfig,
-	engineClient: EngineControlClient,
-	c: HonoContext,
-	actorPathInfo: ReturnType<typeof parseActorPath> & {},
