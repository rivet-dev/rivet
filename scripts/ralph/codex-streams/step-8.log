-	if (basePath.includes("//")) {
-		return null;
-	}
-
-	const segments = basePath.split("/").filter((s) => s.length > 0);
-	if (segments[0] !== "gateway") {
-		return null;
-	}
-
-	const rawQueryStr = rawQuery ?? "";
-
-	// Check if any raw query param key starts with rvt-.
-	const hasRvt =
