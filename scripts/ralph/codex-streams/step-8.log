-			return {
-				getForKey: GetForKeyRequestSchema.parse({
-					name,
-					key: rvt.key,
-				}),
-			};
-		}
-		case "getOrCreate": {
-			if (rvt.runner === undefined) {
-				throw new errors.InvalidRequest(
-					"query gateway method=getOrCreate requires rvt-runner param",
-				);
-			}
