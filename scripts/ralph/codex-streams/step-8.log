-	config: RegistryConfig,
-	engineClient: EngineControlClient,
-	getUpgradeWebSocket: GetUpgradeWebSocket | undefined,
-	c: HonoContext,
-	next: Next,
-) {
-	// Skip test routes - let them be handled by their specific handlers
-	if (c.req.path.startsWith("/.test/")) {
