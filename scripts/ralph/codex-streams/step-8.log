-						created: false,
-					});
-				}
-
-				// Create new actor
-				const newActor = await engineClient.getOrCreateWithKey({
-					c,
-					name: body.name,
-					key: deserializeActorKey(body.key),
-					input: body.input
-						? cbor.decode(Buffer.from(body.input, "base64"))
-						: undefined,
-					region: undefined, // Not provided in the request schema
