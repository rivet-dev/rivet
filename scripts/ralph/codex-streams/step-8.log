-	});
-
-	return await engineClient.proxyWebSocket(
-		c,
-		resolvedActorPathInfo.remainingPath,
-		resolvedActorPathInfo.actorId,
-		encoding as any, // Will be validated by driver
-		connParams,
-	);
-}
