-
-		// GET /
-		router.get("/", (c) => {
-			return c.text(
-				"This is a RivetKit server.\n\nLearn more at https://rivet.dev",
-			);
-		});
-
-		// GET /actors
-		{
-			const route = createRoute({
-				method: "get",
-				path: "/actors",
