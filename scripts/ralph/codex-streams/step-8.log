-function decodeBase64Url(value: string): Uint8Array {
-	if (!/^[A-Za-z0-9_-]*$/.test(value) || value.length % 4 === 1) {
-		throw new errors.InvalidRequest(
-			"invalid base64url in query gateway input",
-		);
