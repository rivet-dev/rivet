-	const target = c.req.header(HEADER_RIVET_TARGET);
-	const actorId = c.req.header(HEADER_RIVET_ACTOR);
-
-	if (target !== "actor") {
-		return next();
-	}
-
-	if (!actorId) {
-		throw new MissingActorHeader();
-	}
-
-	logger().debug({
-		msg: "proxying request to actor",
