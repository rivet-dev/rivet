-function buildRemainingPath(
-	basePath: string,
-	queryString: string,
-	consumedSegments: number,
-): string {
-	const segments = basePath
-		.split("/")
-		.filter((segment) => segment.length > 0);
-
-	let prefixLen = 0;
-	for (let i = 0; i < consumedSegments; i++) {
-		prefixLen += 1 + segments[i].length;
