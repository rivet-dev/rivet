-}
-
-function buildActorQuery(name: string, rvt: RvtParams): ActorGatewayQuery {
-	switch (rvt.method) {
-		case "get": {
-			if (
-				rvt.input !== undefined ||
-				rvt.region !== undefined ||
-				rvt.crashPolicy !== undefined ||
-				rvt.runner !== undefined
