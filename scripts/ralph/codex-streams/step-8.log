-		const actorQueryString = stripRvtQueryParams(rawQueryStr);
-		return parseQueryActorPath(
-			basePath,
-			segments,
-			rvtParams,
-			actorQueryString,
-		);
-	}
-
-	// Direct path: pass the raw query string through unchanged.
-	const rawQueryString = rawQuery !== null ? `?${rawQuery}` : "";
