-	const proxyRequest = new Request(proxyUrl, {
-		method: c.req.raw.method,
-		headers: proxyHeaders,
-		body: c.req.raw.body,
-		signal: c.req.raw.signal,
-		duplex: "half",
-	} as RequestInit);
-
-	return await engineClient.proxyRequest(c, proxyRequest, actorId);
-}
