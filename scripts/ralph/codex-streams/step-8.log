-	if (target !== "actor") {
-		return next();
-	}
-
-	if (!actorId) {
-		throw new MissingActorHeader();
-	}
-
-	logger().debug({
-		msg: "proxying request to actor",
-		actorId,
-		path: strippedPath,
-		method: c.req.method,
-	});
-
-	// Preserve all headers except the routing headers
-	const proxyHeaders = new Headers(c.req.raw.headers);
