-	}
-
-	if (nameSegment.includes("@")) {
-		throw new errors.InvalidRequest(
-			"query gateway paths must not use @token syntax",
-		);
-	}
-
-	let name: string;
-	try {
-		name = decodeURIComponent(nameSegment);
