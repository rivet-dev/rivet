-								msg: "failed to convert blob to arraybuffer",
-								error,
-							});
-						});
-				} else {
-					logger().debug({
-						msg: "sending data directly",
-						dataType: typeof evt.data,
-						dataLength:
-							typeof evt.data === "string"
-								? evt.data.length
-								: undefined,
-					});
-					proxyToActorWs.send(evt.data);
