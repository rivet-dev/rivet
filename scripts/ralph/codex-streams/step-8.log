-				reason: event.reason,
-			});
-
-			// HACK: Close socket in order to fix bug with Cloudflare leaving WS in closing state
-			// https://github.com/cloudflare/workerd/issues/2569
-			clientToProxyWs.close(1000, "hack_force_close");
