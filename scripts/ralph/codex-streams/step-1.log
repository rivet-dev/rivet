}

interface ReferenceLike<T> {
	apply(
		receiver: unknown,
		args: unknown[],
		options?: Record<string, unknown>,
	): unknown;
	release?(): void;
}

interface NodeProcessLike {
	__unsafeIsoalte: {
		compileScript(
			code: string,
			options?: Record<string, unknown>,
		): Promise<{ run(context: unknown): Promise<void> }>;
	};
	__unsafeCreateContext(
		options?: Record<string, unknown>,
	): Promise<ContextLike>;
