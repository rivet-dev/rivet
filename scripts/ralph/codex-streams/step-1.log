pub type ActorFactoryCreateFn =
	dyn Fn(FactoryRequest) -> BoxFuture<'static, Result<ActorInstanceCallbacks>> + Send + Sync;

pub struct ActorFactory {
	config: ActorConfig,
	create: Box<ActorFactoryCreateFn>,
}

