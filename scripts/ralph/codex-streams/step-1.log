pub struct Schedule(Arc<ScheduleInner>);

struct ScheduleInner {
	state: ActorState,
	actor_id: String,
	generation: Mutex<Option<u32>>,
	config: ActorConfig,
	envoy_handle: Mutex<Option<EnvoyHandle>>,
