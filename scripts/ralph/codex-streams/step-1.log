					.kv_delete(
						self.actor_id.clone(),
						keys.iter().map(|key| key.to_vec()).collect(),
					)
					.await
			}
			#[cfg(test)]
			KvBackend::InMemory(entries) => {
				let mut entries = entries.write().expect("in-memory kv lock poisoned");
				for key in keys {
					entries.remove(*key);
				}
				Ok(())
			}
			KvBackend::Unconfigured => Err(anyhow!("kv handle is not configured")),
		}
	}
}

