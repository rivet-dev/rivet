+		&mut self.0
+	}
+}
+
+impl From<http::Response<Vec<u8>>> for Response {
+	fn from(value: http::Response<Vec<u8>>) -> Self {
+		Self(value)
+	}
+}
+
+impl From<Response> for http::Response<Vec<u8>> {
+	fn from(value: Response) -> Self {
+		value.0
+	}
