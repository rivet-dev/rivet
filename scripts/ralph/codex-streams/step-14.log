+				.parse()
+				.map_err(|error| anyhow!("invalid response header name `{name}`: {error}"))?;
+			let header_value: http::header::HeaderValue = value
+				.parse()
+				.map_err(|error| anyhow!("invalid response header `{name}` value: {error}"))?;
