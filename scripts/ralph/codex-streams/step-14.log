+		assert_eq!(config.sleep_grace_period, Some(Duration::from_secs(12)));
+		assert_eq!(config.max_queue_size, 42);
+		assert_eq!(config.preload_max_workflow_bytes, Some(1024));
+	}
+
+	#[test]
