+	}
+
+	pub fn from_parts(
+		status: u16,
+		headers: HashMap<String, String>,
+		body: Vec<u8>,
+	) -> Result<Self> {
+		let mut response = http::Response::new(body);
+		*response.status_mut() = status
+			.try_into()
+			.map_err(|error| anyhow!("invalid http response status `{status}`: {error}"))?;
