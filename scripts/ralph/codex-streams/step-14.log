+					)
+				})
+				.collect(),
+			self.body().clone(),
+		)
+	}
+
+	pub fn into_inner(self) -> http::Response<Vec<u8>> {
+		self.0
+	}
+
+	pub fn into_body(self) -> Vec<u8> {
+		self.0.into_body()
+	}
+}
+
+impl Default for Response {
