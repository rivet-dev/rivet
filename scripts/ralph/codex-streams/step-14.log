+			default.max_queue_message_size,
+		);
+		assert_eq!(
+			config.preload_max_workflow_bytes,
+			default.preload_max_workflow_bytes,
+		);
+		assert_eq!(
+			config.preload_max_connections_bytes,
+			default.preload_max_connections_bytes,
