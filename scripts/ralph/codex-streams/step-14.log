+		);
+		assert_eq!(
+			config.preload_max_connections_bytes,
+			default.preload_max_connections_bytes,
+		);
+		assert!(matches!(
+			config.can_hibernate_websocket,
+			super::CanHibernateWebSocket::Bool(false),
+		));
+		assert!(config.overrides.is_none());
+	}
+}
