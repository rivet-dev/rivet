+			name: Some("demo".to_owned()),
+			on_sleep_timeout_ms: Some(9_000),
+			sleep_grace_period_ms: Some(12_000),
+			max_queue_size: Some(42),
+			preload_max_workflow_bytes: Some(1024.0),
+			..FlatActorConfig::default()
