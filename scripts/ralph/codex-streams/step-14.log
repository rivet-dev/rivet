+
+		assert_eq!(config.name, default.name);
+		assert_eq!(config.icon, default.icon);
+		assert_eq!(config.state_save_interval, default.state_save_interval);
+		assert_eq!(config.create_vars_timeout, default.create_vars_timeout);
+		assert_eq!(
