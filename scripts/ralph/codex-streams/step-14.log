+	pub fn from_parts(
+		method: &str,
+		uri: &str,
+		headers: HashMap<String, String>,
+		body: Vec<u8>,
+	) -> Result<Self> {
+		let method = method
+			.parse::<http::Method>()
+			.map_err(|error| anyhow!("invalid request method `{method}`: {error}"))?;
