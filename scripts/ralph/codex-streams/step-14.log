+		assert_eq!(method, "POST");
+		assert_eq!(uri, "/actors?id=1");
+		assert_eq!(
+			headers.get("content-type"),
+			Some(&"application/cbor".to_owned())
+		);
+		assert_eq!(body, vec![1, 2, 3]);
