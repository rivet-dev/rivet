+		assert_eq!(response.headers()["x-test"], "ok");
+
+		let (status, headers, body) = response.to_parts();
+		assert_eq!(status, StatusCode::CREATED.as_u16());
+		assert_eq!(headers.get("x-test"), Some(&"ok".to_owned()));
+		assert_eq!(body, b"done");
+	}
