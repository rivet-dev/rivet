+				.headers()
+				.iter()
+				.map(|(name, value)| {
+					(
+						name.to_string(),
+						String::from_utf8_lossy(value.as_bytes()).into_owned(),
+					)
+				})
+				.collect(),
+			self.body().clone(),
+		)
+	}
 
