+				};
+				callback(GetWorkflowHistoryRequest { ctx }).await
+			})
+		}) as Arc<
+			dyn Fn() -> futures::future::BoxFuture<'static, Result<Option<Vec<u8>>>>
+				+ Send
+				+ Sync,
+		>
+	});
+	let replay_workflow = callbacks.replay_workflow.as_ref().map(|_| {
