function toBuffer(value: string | Uint8Array | ArrayBuffer): Buffer {
	if (typeof value === "string") {
		return Buffer.from(textEncoder.encode(value));
	}
	if (value instanceof Uint8Array) {
		return Buffer.from(value);
	}
	return Buffer.from(value);
