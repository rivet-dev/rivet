+	async fn inspector_workflow_history(
+		&self,
+		instance: &ActiveActorInstance,
+	) -> Result<(bool, Option<JsonValue>)> {
+		let is_workflow_enabled = instance.inspector.is_workflow_enabled();
+		if !is_workflow_enabled {
+			return Ok((false, None));
+		}
+
