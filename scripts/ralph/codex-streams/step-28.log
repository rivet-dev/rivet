+		if !is_workflow_enabled {
+			return Ok((false, None));
+		}
+
+		let history = instance
+			.inspector
+			.replay_workflow(entry_id)
+			.await
+			.context("replay inspector workflow history")?
+			.map(|payload| decode_cbor_json_or_null(&payload))
+			.filter(|value| !value.is_null());
+
+		Ok((true, history))
