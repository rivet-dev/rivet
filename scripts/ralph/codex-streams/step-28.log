+		.call_async::<Promise<Option<Buffer>>>(Ok(payload))
+		.await
+		.map_err(|error| callback_error(callback_name, error))?;
+	let buffer = promise
+		.await
+		.map_err(|error| callback_error(callback_name, error))?;
+	Ok(buffer.map(|buffer| buffer.to_vec()))
