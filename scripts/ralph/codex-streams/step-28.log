	}

	get vars(): unknown {
		return createWriteThroughProxy(
			decodeValue(callNativeSync(() => this.#ctx.vars())),
			(nextValue) =>
				callNativeSync(() => this.#ctx.setVars(encodeValue(nextValue))),
		);
	}

	set vars(value: unknown) {
		callNativeSync(() => this.#ctx.setVars(encodeValue(value)));
