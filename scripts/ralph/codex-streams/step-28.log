+fn wrap_optional_buffer_callback<Req, Payload, Map>(
+	callback_name: &'static str,
+	callback: &Option<CallbackTsfn<Payload>>,
+	map: Map,
+) -> Option<Box<dyn Fn(Req) -> BoxFuture<'static, Result<Option<Vec<u8>>>> + Send + Sync>>
