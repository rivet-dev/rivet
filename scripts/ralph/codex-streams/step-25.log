						status: "COMPLETED",
						error: null,
						attempts: 1,
						lastAttemptAt: 10n,
						createdAt: 5n,
						completedAt: 10n,
						rollbackCompletedAt: null,
						rollbackError: null,
					},
				],
			]),
		};

		const encoded = encodeWorkflowHistoryTransport(history);
		const decoded = decodeWorkflowHistoryTransport(encoded);

		expect(decoded).toEqual(history);
	});
});

