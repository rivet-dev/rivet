+			(http::Method::GET, "/inspector/traces") => json_http_response(
+				StatusCode::OK,
+				&json!({
+					"otlp": Vec::<u8>::new(),
+					"clamped": false,
+				}),
+			),
+			(http::Method::GET, "/inspector/database/schema") => {
+				self
+					.inspector_database_schema(&instance.ctx)
+					.await
+					.context("load inspector database schema")
+					.and_then(|payload| {
