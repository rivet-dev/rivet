+					Ok(limit) => limit,
+					Err(response) => return Ok(Some(response)),
+				};
+				let messages = match instance
+					.ctx
+					.queue()
+					.inspect_messages()
+					.await
+				{
+					Ok(messages) => messages,
+					Err(error) => {
+						return Ok(Some(inspector_anyhow_response(
