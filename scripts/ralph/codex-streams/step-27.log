+			.db_query(
+				&format!(
+					"SELECT * FROM {} LIMIT ? OFFSET ?",
+					quote_sql_identifier(table)
+				),
+				Some(&params),
+			)
+			.await
+			.with_context(|| format!("query rows for `{table}`"))?;
+		Ok(decode_cbor_json_or_null(&rows))
