+				let limit = match parse_u32_query_param(&url, "limit", 100) {
+					Ok(limit) => limit,
+					Err(response) => return Ok(Some(response)),
+				};
+				let offset = match parse_u32_query_param(&url, "offset", 0) {
+					Ok(offset) => offset,
