+			InspectorSnapshot {
+				queue_revision: 4,
+				queue_size: 1,
+				..InspectorSnapshot::default()
+			},
+		);
+
+		completable
+			.complete(Some(vec![7]))
+			.await
+			.expect("queue ack should succeed");
+		assert_eq!(
+			inspector.snapshot(),
+			InspectorSnapshot {
+				queue_revision: 5,
+				queue_size: 0,
+				..InspectorSnapshot::default()
+			},
+		);
+	}
+}
