};

type InspectorConnDriverSymbolCarrier = {
	[CONN_DRIVER_SYMBOL]?: { type?: string };
};

interface InspectorConnection
	extends InspectorConnStateSymbolCarrier,
		InspectorConnDriverSymbolCarrier {
	params?: unknown;
	subscriptions?: { size: number };
