+				queue_revision: 2,
+				queue_size: 0,
+				..InspectorSnapshot::default()
+			},
+		);
+
+		ctx.queue()
+			.send("jobs", b"second")
+			.await
+			.expect("second enqueue should succeed");
+		assert_eq!(
+			inspector.snapshot(),
+			InspectorSnapshot {
+				queue_revision: 3,
+				queue_size: 1,
+				..InspectorSnapshot::default()
+			},
+		);
+
+		let completable = ctx
+			.queue()
+			.next(QueueNextOpts {
+				names: None,
+				timeout: None,
+				signal: None,
+				completable: true,
+			})
+			.await
+			.expect("completable receive should succeed")
+			.expect("completable message should exist");
+		assert_eq!(
+			inspector.snapshot(),
+			InspectorSnapshot {
+				queue_revision: 4,
+				queue_size: 1,
+				..InspectorSnapshot::default()
+			},
+		);
+
+		completable
+			.complete(Some(vec![7]))
+			.await
+			.expect("queue ack should succeed");
+		assert_eq!(
+			inspector.snapshot(),
+			InspectorSnapshot {
+				queue_revision: 5,
+				queue_size: 0,
+				..InspectorSnapshot::default()
+			},
+		);
+	}
+}

