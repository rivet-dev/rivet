+			.fetch_add(1, Ordering::SeqCst);
+	}
+
+	pub(crate) fn record_queue_updated(&self, queue_size: u32) {
+		self.0.queue_size.store(queue_size, Ordering::SeqCst);
+		self.0.queue_revision.fetch_add(1, Ordering::SeqCst);
