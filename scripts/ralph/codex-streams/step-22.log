+		schema !== null &&
+		"complete" in schema
+	) {
+		const candidate = (schema as { complete?: unknown }).complete;
+		if (candidate !== undefined) {
+			completeSchema = candidate as PrimitiveSchema;
+		}
+	}
+
+	if (!completeSchema) {
+		return response;
+	}
+
+	const result = validateSchemaSync(
+		{ [name]: completeSchema } as EventSchemaConfig,
+		name,
+		response,
+	);
