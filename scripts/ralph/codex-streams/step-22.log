+			.queue()
+			.enqueue_and_wait(
+				"jobs",
+				b"payload",
+				EnqueueAndWaitOpts {
+					timeout: Some(Duration::from_secs(1)),
+					signal: None,
+				},
+			)
+			.await
+			.expect("enqueue_and_wait should succeed");
+
+		consumer.await.expect("consumer join");
+		assert_eq!(response, Some(b"done".to_vec()));
+	}
