+					timeout: Some(Duration::from_millis(0)),
+					signal: None,
+				},
+			)
+			.await
+			.expect_err("enqueue_and_wait should time out");
+		let error = rivet_error::RivetError::extract(&error);
+		assert_eq!(error.group(), "queue");
+		assert_eq!(error.code(), "timed_out");
+	}
