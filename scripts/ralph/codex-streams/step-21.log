+			Vec::new(),
+			"local",
+			crate::kv::tests::new_in_memory(),
+		);
+
+		let error = ctx
+			.queue()
+			.wait_for_names(
+				vec!["missing".into()],
+				QueueWaitOpts {
+					timeout: Some(Duration::from_millis(0)),
+					signal: None,
+					completable: false,
+				},
+			)
+			.await
+			.expect_err("wait for names should time out");
