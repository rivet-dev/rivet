		return;
	}

	waitForMessages(
		messageNames: string[],
		abortSignal: AbortSignal,
	): Promise<void> {
		return this.#actor.queueManager.waitForNames(
			messageNames.length > 0 ? messageNames : undefined,
			abortSignal,
		);
	}
}

