+async function createNativeCancellationToken(signal?: AbortSignal): Promise<{
+	token?: { cancel(): void };
+	dispose: () => void;
+}> {
+	if (!signal) {
+		return {
+			token: undefined,
+			dispose: () => undefined,
+		};
+	}
+
+	const bindings = await loadNativeBindings();
+	const token = new bindings.CancellationToken();
+	const forwardAbort = () => token.cancel();
+
+	if (signal.aborted) {
+		forwardAbort();
+		return {
+			token,
+			dispose: () => undefined,
+		};
+	}
+
+	signal.addEventListener("abort", forwardAbort, { once: true });
+	return {
+		token,
+		dispose: () => signal.removeEventListener("abort", forwardAbort),
+	};
+}
