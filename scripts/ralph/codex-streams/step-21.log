+		let ctx = new_with_kv(
+			"actor-1",
+			"queue-wait-signal-abort",
+			Vec::new(),
+			"local",
+			crate::kv::tests::new_in_memory(),
+		);
+		let signal = CancellationToken::new();
+		let queue = ctx.queue().clone();
+		let signal_for_task = signal.clone();
+
+		let wait_task = tokio::spawn(async move {
+			queue
+				.wait_for_names(
+					vec!["missing".into()],
