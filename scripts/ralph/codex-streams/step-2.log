+/// N-API wrapper around `rivetkit-core::ActorContext`.
+#[napi]
+pub struct ActorContext {
+	inner: CoreActorContext,
+}
+
+impl ActorContext {
+	pub(crate) fn new(inner: CoreActorContext) -> Self {
+		Self { inner }
+	}
+
+	#[allow(dead_code)]
