+			if ("vars" in config) {
+				result.vars = encodeValue(config.vars);
+				actorCtx.vars = config.vars;
+			} else if (typeof config.createVars === "function") {
+				const vars = await config.createVars(actorCtx, undefined);
+				result.vars = encodeValue(vars);
+				actorCtx.vars = vars;
+			}
