		) {
			this.#config.publicEndpoint = `http://127.0.0.1:${httpPort}`;
			this.#config.serverless.publicEndpoint =
				this.#config.publicEndpoint;
		}
		this.#config.httpPort = httpPort;

		let serverApp = runtimeRouter;
