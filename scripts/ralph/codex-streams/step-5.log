+function buildNativeFactory(
+	bindings: NativeBindings,
+	definition: AnyActorDefinition,
+): NativeActorFactory {
+	const config = definition.config as Record<string, any>;
+	const callbacks = {
+		onInit: async ({
+			ctx,
+			input,
+			isNew,
+		}: {
+			ctx: NativeActorContext;
+			input?: Buffer;
+			isNew: boolean;
+		}): Promise<JsFactoryInitResult> => {
