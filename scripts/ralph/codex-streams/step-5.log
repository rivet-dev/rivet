			super(type);
			this.code = init.code ?? 0;
			this.reason = init.reason ?? "";
			this.wasClean = init.wasClean ?? false;
		}
	};
}

// Re-export protocol for consumers that need protocol types at runtime
let _protocol;
try {
	_protocol = require("@rivetkit/engine-envoy-protocol");
} catch {
	_protocol = {};
