+						return await toJsHttpResponse(
+							response,
+						);
+					}
+				: undefined,
+		onWebSocket:
+			typeof config.onWebSocket === "function"
+				? async ({
+						ctx,
+						ws,
+					}: {
+						ctx: NativeActorContext;
+						ws: NativeWebSocket;
+					}) =>
+						await config.onWebSocket(
+							new NativeActorContextAdapter(ctx),
+							new NativeWebSocketAdapter(ws),
+						)
+				: undefined,
