+					name,
+					async ({
+						ctx,
+						conn,
+					args,
+				}: {
+					ctx: NativeActorContext;
+					conn: NativeConnHandle;
+					args: Buffer;
+				}) =>
+					encodeValue(
+						await handler(
+							withConnContext(ctx, conn),
+							...decodeArgs(args),
+						),
+					),
+				]),
+			),
+		};
