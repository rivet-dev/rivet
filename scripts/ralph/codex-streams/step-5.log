+} from "@rivetkit/rivetkit-napi";
+
+type NativeBindings = typeof import("@rivetkit/rivetkit-napi");
+
+async function loadNativeBindings(): Promise<NativeBindings> {
+	return import(["@rivetkit", "rivetkit-napi"].join("/"));
