{
	"name": "@rivetkit/cloudflare-workers",
	"version": "2.1.10",
	"description": "Cloudflare Workers adapter for RivetKit actors",
	"keywords": [
		"rivetkit",
		"cloudflare",
		"actors",
		"edge",
		"platform",
		"serverless"
	],
	"files": [
		"src",
		"dist",
		"package.json"
	],
	"type": "module",
	"rivetkit": {
		".": "src/mod.ts",
		"./tsconfig": {
			"static": "dist/tsconfig.json"
		}
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.js"
			},
			"require": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.cjs"
			}
		},
		"./tsconfig": "./dist/tsconfig.json"
	},
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"scripts": {
		"build": "tsup src/mod.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit",
		"test": "vitest run tests"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250129.0",
		"@types/invariant": "^2",
		"@types/node": "^24.0.3",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2",
		"vitest": "^3.1.1",
		"wrangler": "^4.22.0"
	},
	"dependencies": {
		"invariant": "^2.2.4",
		"zod": "^4.1.0",
		"hono": "^4.7.0",
		"rivetkit": "workspace:*"
	},
	"stableVersion": "0.8.0",
	"engines": {
		"node": ">=22.0.0"
	}
}
