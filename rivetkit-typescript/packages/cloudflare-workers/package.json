{
	"name": "@rivetkit/cloudflare-workers",
	"version": "2.3.0-rc.13",
	"description": "Cloudflare Workers integration for RivetKit actors",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"cloudflare",
		"cloudflare-workers",
		"workers",
		"workerd",
		"serverless",
		"edge",
		"wasm",
		"actor",
		"microservices"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./src/websocket.ts"
	],
	"files": [
		"dist",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.mts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@rivetkit/rivetkit-wasm": "workspace:*",
		"rivetkit": "workspace:^"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0"
}
