{
	"name": "@rivetkit/query-core",
	"version": "2.1.6",
	"description": "Query cache integration utilities for RivetKit clients",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"query",
		"cache",
		"integration",
		"tanstack"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs"
	],
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.mts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@rivetkit/framework-base": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0"
}
