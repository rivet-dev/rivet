{
	"name": "@rivetkit/framework-base",
	"version": "2.1.10",
	"description": "Base framework utilities for RivetKit client integrations",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"framework",
		"base",
		"utilities",
		"integration"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"rivetkit": {
		".": "src/mod.ts"
	},
	"files": [
		"dist",
		"package.json",
		"src"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.js"
			},
			"require": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0",
	"dependencies": {
		"@tanstack/store": "^0.7.1",
		"fast-deep-equal": "^3.1.3",
		"rivetkit": "workspace:*"
	},
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	}
}
