{
	"name": "@rivetkit/react",
	"version": "2.1.7",
	"description": "React hooks and components for RivetKit client applications",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"react",
		"hooks",
		"components",
		"frontend",
		"ui"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs"
	],
	"files": [
		"dist",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.mts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@rivetkit/framework-base": "workspace:*",
		"@tanstack/react-store": "^0.7.1",
		"rivetkit": "workspace:^"
	},
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"jsdom": "^26.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2",
		"vitest": "^3.1.1"
	},
	"stableVersion": "0.8.0"
}
