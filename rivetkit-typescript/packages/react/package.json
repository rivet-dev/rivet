{
	"name": "@rivetkit/react",
	"version": "2.1.10",
	"description": "React hooks and components for RivetKit client applications",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"react",
		"hooks",
		"components",
		"frontend",
		"ui"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"rivetkit": {
		".": "src/mod.ts"
	},
	"files": [
		"dist",
		"package.json",
		"src"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.js"
			},
			"require": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@rivetkit/framework-base": "workspace:*",
		"@tanstack/react-store": "^0.7.1",
		"rivetkit": "workspace:^"
	},
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"devDependencies": {
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	}
}
