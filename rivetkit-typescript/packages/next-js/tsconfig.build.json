{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"types": [
			"node"
		],
		"resolveJsonModule": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": true,
		"outDir": "dist/types",
		"declarationDir": "dist/types",
		"rootDir": "src",
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"src/**/*.test.ts"
	],
	"references": [
		{
			"path": "../react/tsconfig.build.json"
		},
		{
			"path": "../rivetkit/tsconfig.build.json"
		}
	]
}
