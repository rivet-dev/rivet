{
	"name": "@rivetkit/next-js",
	"version": "2.1.10",
	"description": "Next.js integration for RivetKit actors and client",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"nextjs",
		"next",
		"nextjs-framework",
		"next-js",
		"react",
		"framework",
		"web",
		"serverless",
		"edge",
		"actor",
		"microservices"
	],
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"rivetkit": {
		".": "src/mod.ts",
		"./client": "src/client/mod.ts"
	},
	"files": [
		"dist",
		"package.json",
		"src"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.js"
			},
			"require": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.cjs"
			}
		},
		"./client": {
			"import": {
				"types": "./dist/types/client/mod.d.ts",
				"default": "./dist/client/mod.js"
			},
			"require": {
				"types": "./dist/types/client/mod.d.ts",
				"default": "./dist/client/mod.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts src/client/mod.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@rivetkit/react": "workspace:*",
		"hono": "^4.8.3",
		"rivetkit": "workspace:^"
	},
	"peerDependencies": {
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"tsup": "^8.4.0",
		"typescript": "^5.5.2"
	},
	"stableVersion": "0.8.0",
	"type": "module",
	"engines": {
		"node": ">=22.0.0"
	}
}
