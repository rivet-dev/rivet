{
	"name": "@rivetkit/traces",
	"version": "2.1.10",
	"description": "Generic tracing storage and OTLP export for RivetKit",
	"license": "Apache-2.0",
	"type": "module",
	"rivetkit": {
		"outDir": "dist/tsup",
		"typesDir": "dist/types/src",
		"rootDir": ".",
		"browserOutDir": "dist/tsup",
		"preBuild": "pnpm run compile:bare",
		".": {
			"default": "src/index.ts",
			"browser": "src/index.browser.ts"
		},
		"./encoding": "src/encoding.ts",
		"./otlp": "src/otlp-entry.ts"
	},
	"files": [
		"dist",
		"src",
		"schemas",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"browser": {
					"types": "./dist/types/src/index.browser.d.ts",
					"default": "./dist/tsup/index.browser.js"
				},
				"types": "./dist/types/src/index.d.ts",
				"default": "./dist/tsup/index.js"
			},
			"require": {
				"types": "./dist/types/src/index.d.ts",
				"default": "./dist/tsup/index.cjs"
			}
		},
		"./encoding": {
			"import": {
				"types": "./dist/types/src/encoding.d.ts",
				"default": "./dist/tsup/encoding.js"
			},
			"require": {
				"types": "./dist/types/src/encoding.d.ts",
				"default": "./dist/tsup/encoding.cjs"
			}
		},
		"./otlp": {
			"import": {
				"types": "./dist/types/src/otlp-entry.d.ts",
				"default": "./dist/tsup/otlp-entry.js"
			},
			"require": {
				"types": "./dist/types/src/otlp-entry.d.ts",
				"default": "./dist/tsup/otlp-entry.cjs"
			}
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "pnpm run compile:bare && tsup src/index.ts src/index.browser.ts src/encoding.ts src/otlp-entry.ts && tsc -p tsconfig.build.json --noCheck",
		"compile:bare": "tsx scripts/compile-bare.ts compile schemas/v1.bare -o dist/schemas/v1.ts",
		"check-types": "tsc --noEmit",
		"test": "pnpm run compile:bare && vitest run"
	},
	"dependencies": {
		"@rivetkit/bare-ts": "^0.6.2",
		"fdb-tuple": "^1.0.0",
		"cbor-x": "^1.6.0",
		"vbare": "^0.0.4"
	},
	"devDependencies": {
		"@bare-ts/tools": "^0.13.0",
		"@types/node": "^22.13.1",
		"commander": "^12.0.0",
		"tsx": "^4.7.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^3.1.1"
	},
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	]
}
