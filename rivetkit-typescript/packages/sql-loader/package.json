{
	"name": "@rivetkit/sql-loader",
	"version": "2.1.10",
	"description": "SQL file loader and migration utilities for RivetKit",
	"license": "Apache-2.0",
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	],
	"type": "module",
	"rivetkit": {
		".": "src/register.ts",
		"./hook": "src/hook.ts"
	},
	"files": [
		"dist",
		"package.json",
		"src"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/register.d.ts",
				"default": "./dist/register.js"
			},
			"require": {
				"types": "./dist/types/register.d.ts",
				"default": "./dist/register.cjs"
			}
		},
		"./hook": {
			"import": {
				"types": "./dist/types/hook.d.ts",
				"default": "./dist/hook.js"
			},
			"require": {
				"types": "./dist/types/hook.d.ts",
				"default": "./dist/hook.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup src/register.ts src/hook.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"tsup": "^8.5.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
