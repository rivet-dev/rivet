{
	"name": "@rivetkit/effect",
	"version": "2.0.42-rc.1",
	"description": "Effect-TS integration for RivetKit actors with typed context, lifecycle wrappers, and managed runtime support",
	"license": "Apache-2.0",
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs"
	],
	"type": "module",
	"files": [
		"dist",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/mod.d.mts",
				"default": "./dist/mod.mjs"
			},
			"require": {
				"types": "./dist/mod.d.ts",
				"default": "./dist/mod.js"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"rivetkit": "workspace:^"
	},
	"peerDependencies": {
		"effect": ">=3.0.0"
	},
	"devDependencies": {
		"@effect/vitest": "^0.27.0",
		"effect": "^3.16.0",
		"tsup": "^8.5.0",
		"typescript": "^5.9.2",
		"vitest": "^3.1.1"
	}
}
