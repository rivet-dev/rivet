{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"composite": true,
		"types": [
			"node"
		],
		"resolveJsonModule": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": true,
		"outDir": "dist/types",
		"declarationDir": "dist/types",
		"rootDir": ".",
		"skipLibCheck": true,
		"paths": {
			"@/*": [
				"./src/*"
			]
		}
	},
	"include": [
		"src/**/*",
		"runtime/index.ts",
		"dist/schemas/**/*"
	],
	"exclude": [
		"src/**/*.test.ts",
		"fixtures/**/*"
	],
	"references": [
		{
			"path": "../../../engine/sdks/typescript/runner/tsconfig.build.json"
		},
		{
			"path": "../sqlite-vfs/tsconfig.build.json"
		},
		{
			"path": "../traces/tsconfig.build.json"
		},
		{
			"path": "../../../shared/typescript/virtual-websocket/tsconfig.build.json"
		},
		{
			"path": "../workflow-engine/tsconfig.build.json"
		}
	]
}
