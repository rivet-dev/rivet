{
	"extends": "../../../../tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": "..",
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node"],
		"lib": ["ES2022", "DOM"],
		"resolveJsonModule": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.cts", "../src/dynamic/runtime-bridge.ts"]
}
