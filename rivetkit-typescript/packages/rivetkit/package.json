		"src",
		"deno.json",
		"bun.json",
		"package.json"
	],
	"type": "module",
	"rivetkit": {
		"outDir": "dist/tsup",
		"typesDir": "dist/types/src",
		"preBuild": "pnpm run build:schema",
		".": "src/mod.ts",
		"./workflow": "src/workflow/mod.ts",
		"./client": {
			"default": "src/client/mod.ts",
			"browser": "src/client/mod.browser.ts",
			"browserName": "client"
		},
		"./log": "src/common/log.ts",
		"./errors": "src/actor/errors.ts",
		"./utils": "src/utils.ts",
