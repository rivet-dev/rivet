{
	"name": "rivetkit",
	"version": "2.1.10",
	"description": "Lightweight libraries for building stateful actors on edge platforms",
	"license": "Apache-2.0",
	"keywords": [
		"rivetkit",
		"stateful",
		"serverless",
		"actors",
		"agents",
		"realtime",
		"websocket",
		"actors",
		"framework"
	],
