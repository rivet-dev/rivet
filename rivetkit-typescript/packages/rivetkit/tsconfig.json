{
	"extends": "../../../tsconfig.base.json",
	"compilerOptions": {
		"types": ["node"],
		"resolveJsonModule": true,
		"paths": {
			"@/*": ["./src/*"],
			// Used for test fixtures
			"rivetkit": ["./src/mod.ts"],
			"rivetkit/dynamic": ["./src/dynamic/mod.ts"],
			"rivetkit/utils": ["./src/utils.ts"],
			"rivetkit/db": ["./src/db/mod.ts"],
			"rivetkit/db/drizzle": ["./src/db/drizzle/mod.ts"]
		}
	},
	"include": [
		"src/**/*",
		"tests/**/*",
		"scripts/**/*",
		"fixtures/driver-test-suite/**/*",
		"dist/schemas/**/*"
, "runtime/index.ts"	]
}
