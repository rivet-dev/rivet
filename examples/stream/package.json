		"concurrently": "^9.1.2",
		"tsx": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.0",
		"vitest": "^3.1.1"
	},
	"dependencies": {
		"@rivetkit/react": "^2.1.6-rc.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"rivetkit": "^2.1.6-rc.1"
	},
