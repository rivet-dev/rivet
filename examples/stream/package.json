{
	"name": "example-stream",
	"version": "2.0.21",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n server,vite \"tsx --watch src/index.ts\" \"vite\"",
		"dev:server": "tsx --watch src/index.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"build": "vite build",
		"start": "tsx src/index.ts"
	},
