# Local dev: leave unset — uses the embedded Rivet manager on :6420.
#
# Rivet Cloud (production on Render):
# RIVET_ENDPOINT=https://YOUR_NAMESPACE:sk_YOUR_SECRET@api-YOUR_REGION.rivet.dev
# RIVET_PUBLIC_ENDPOINT=https://YOUR_NAMESPACE:pk_YOUR_PUBLIC@api-YOUR_REGION.rivet.dev
#
# Optional: override auto-derived version for actor draining.
# RIVET_ENVOY_VERSION=42
