{
	"name": "example-raw-websocket-handler-proxy",
	"version": "2.0.21",
	"private": true,
	"type": "module",
	"description": "RivetKit example demonstrating raw WebSocket handler",
	"keywords": [
		"rivetkit",
		"websocket",
		"actor",
		"chat",
		"realtime"
	],
	"scripts": {
		"dev": "concurrently -n server,vite \"tsx --watch src/index.ts\" \"vite\"",
		"dev:server": "tsx --watch src/index.ts",
		"check-types": "echo 'skipped - vite clearScreen type mismatch'",
		"test": "vitest run",
		"build": "vite build",
		"start": "tsx src/index.ts"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/react": "^18.3.16",
		"@types/react-dom": "^18.3.5",
		"@types/ws": "^8.5.10",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.2",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vite": "^6.0.5",
		"vitest": "^3.1.1"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.13",
		"@hono/node-ws": "^1.2.0",
		"@rivetkit/react": "^2.3.0-rc.4",
		"hono": "^4.7.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rivetkit": "^2.3.0-rc.4",
		"ws": "^8.18.0"
	},
	"license": "MIT"
}
