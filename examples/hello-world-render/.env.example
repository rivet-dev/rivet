# Local dev: leave unset to use the embedded Rivet manager on :6420.
#
# Rivet Cloud (production on Render) — use the URLs from the Rivet dashboard.
# Do not commit real tokens.

# Optional: name in GET / JSON probe and startup logs (defaults: RENDER_SERVICE_NAME on Render, else package.json "name").
# SERVICE_NAME=my-app

# Optional: directory for built static files relative to project root (default: public).
# PUBLIC_STATIC_DIR=public

# Optional: local embedded manager port (default 6420; keep in sync with Vite).
# RIVET_MANAGER_PORT=6420

# Server: runner → engine (sk_ token). Use the REGIONAL host from dashboard.rivet.dev for *your* namespace
# (e.g. US West vs EU — each project gets its own api-….rivet.dev). Not global api.rivet.dev
# (runners get must_use_regional_host on the global host).
# RIVET_ENDPOINT=https://YOUR_NAMESPACE:sk_YOUR_SECRET@api-YOUR_RIVET_REGION.rivet.dev

# Client: public API (pk token). Same regional host as above. Required at `npm run build` for production UI.
# RIVET_PUBLIC_ENDPOINT=https://YOUR_NAMESPACE:pk_YOUR_PUBLIC@api-YOUR_RIVET_REGION.rivet.dev

# Optional: override runner version for draining. On Render, omit — version is derived from RENDER_GIT_COMMIT. Legacy alias: RIVET_RUNNER_VERSION.
# RIVET_ENVOY_VERSION=42
