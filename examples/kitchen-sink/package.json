		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"rivetkit": "^2.1.8"
	},
	"devDependencies": {
		"@types/node": "^22.13.9",
		"@types/react": "^18.2.66",
		"@types/react-dom": "^18.2.22",
		"@vitejs/plugin-react": "^4.2.1",
		"concurrently": "^9.1.2",
		"tsx": "^4.7.1",
		"typescript": "^5.2.2",
		"vite": "^5.2.0"
	},
	"license": "MIT"
}
