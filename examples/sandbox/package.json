{
	"name": "sandbox",
	"version": "2.0.21",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.13.1",
	"scripts": {
		"dev": "concurrently -n server,vite \"node --watch --import tsx --loader ./sql-loader.mjs src/index.ts\" \"vite\"",
		"dev:server": "node --watch --import tsx --loader ./sql-loader.mjs src/index.ts",
		"check-types": "echo 'skipped - workflow history types broken'",
		"build": "vite build",
		"start": "node --import tsx --loader ./sql-loader.mjs src/index.ts",
		"db:generate": "find src/actors -name drizzle.config.ts -exec drizzle-kit generate --config {} \\;"
	},
	"devDependencies": {
		"@types/node": "^22.13.9",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@vitejs/plugin-react": "^4.2.0",
		"concurrently": "^9.1.2",
		"drizzle-kit": "^0.31.2",
		"typescript": "^5.5.2",
		"vite": "^5.0.0"
	},
	"dependencies": {
		"@ai-sdk/openai": "^0.0.66",
		"drizzle-orm": "^0.44.2",
		"@rivetkit/react": "2.1.7",
		"ai": "^4.0.38",
		"fdb-tuple": "^1.0.0",
		"hono": "^4.11.3",
		"lucide-react": "^0.439.0",
		"mermaid": "^11.12.2",
		"prism-react-renderer": "^2.4.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"rivetkit": "2.1.7",
		"tsx": "^3.12.7",
		"zod": "^3.25.69"
	},
	"stableVersion": "0.8.0",
	"license": "MIT"
}
