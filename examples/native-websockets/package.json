{
	"name": "native-websockets",
	"version": "2.0.21",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n server,vite \"tsx --watch src/index.ts\" \"vite\"",
		"dev:server": "tsx --watch src/index.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"build": "vite build",
		"start": "tsx src/index.ts"
	},
	"devDependencies": {
		"@types/node": "^22.13.9",
		"@types/react": "^18.2.0",
		"@types/react-dom": "^18.2.0",
		"@types/ws": "^8.5.10",
		"@vitejs/plugin-react": "^4.2.0",
		"concurrently": "^9.1.2",
		"tsx": "^3.12.7",
		"typescript": "^5.5.2",
		"vite": "^5.0.0",
		"vitest": "^3.1.1",
		"ws": "^8.16.0"
	},
	"dependencies": {
		"@rivetkit/react": "^2.2.1",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"rivetkit": "^2.2.1"
	},
	"license": "MIT"
}
