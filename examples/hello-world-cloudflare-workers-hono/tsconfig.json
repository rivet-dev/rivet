{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": ["node"],
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src/**/*", "scripts/**/*"]
}
