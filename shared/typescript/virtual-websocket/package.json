{
	"name": "@rivetkit/virtual-websocket",
	"version": "2.0.33",
	"description": "Virtual WebSocket implementation for creating linked WebSocket pairs",
	"license": "Apache-2.0",
	"type": "module",
	"rivetkit": {
		".": "src/mod.ts"
	},
	"files": [
		"dist",
		"src",
		"package.json"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.js"
			},
			"require": {
				"types": "./dist/types/mod.d.ts",
				"default": "./dist/mod.cjs"
			}
		}
	},
	"scripts": {
		"build": "tsup src/mod.ts && tsc -p tsconfig.build.json --noCheck",
		"check-types": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^22.13.1",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3"
	},
	"stableVersion": "0.8.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"sideEffects": [
		"./dist/chunk-*.js",
		"./dist/chunk-*.cjs",
		"./dist/tsup/chunk-*.js",
		"./dist/tsup/chunk-*.cjs"
	]
}
